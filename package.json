{
  "name": "wallpaper-orchestrator",
  "version": "0.4.0",
  "description": "Desktop app that organizes local image collections into category folders, hosts them on GitHub, and builds a Pinterest bulk-upload CSV with tags and links.",
  "main": "main.js",
  "author": {
    "name": "FallenOWL"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/egorlintos-spec/wallpaper-orchestrator.git"
  },
  "bugs": {
    "url": "https://github.com/egorlintos-spec/wallpaper-orchestrator/issues"
  },
  "homepage": "https://github.com/egorlintos-spec/wallpaper-orchestrator#readme",
  "keywords": [
    "electron",
    "pinterest",
    "csv",
    "bulk-upload",
    "wallpaper",
    "github-hosting",
    "automation"
  ],
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "to.boosty.fallenowl.wallpaperorchestrator",
    "productName": "Wallpaper Orchestrator",
    "files": [
      "main.js",
      "preload.js",
      "config.js",
      "core/github_client.js",
      "core/csv_builder.js",
      "core/pack_manager.js",
      "core/image_optimizer.js",
      "gui/**/*",
      "!**/*.map"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Wallpaper-Orchestrator-${version}-Windows-Setup-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.icns",
      "artifactName": "Wallpaper-Orchestrator-${version}-macOS-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics",
      "icon": "build/icon.png",
      "maintainer": "FallenOWL",
      "artifactName": "Wallpaper-Orchestrator-${version}-Linux-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "egorlintos-spec",
        "repo": "wallpaper-orchestrator"
      }
    ],
    "portable": {
      "artifactName": "Wallpaper-Orchestrator-${version}-Windows-Portable-${arch}.${ext}"
    },
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**"
    ]
  }
}
