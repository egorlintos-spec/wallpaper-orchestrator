# Optional overrides (all have sensible defaults in config.js)

# Remote-debugging endpoint of the Chrome you log into ChatGPT with
CDP_URL=http://localhost:9222
CDP_PORT=9222

# Path to your Chrome executable
CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe

# Chrome user-data dir that holds your ChatGPT session
# CHROME_PROFILE_DIR=C:\Users\you\AppData\Local\.SaiChromeProfile
