# === Reve AI image API (REQUIRED) ===
# Get your key at the Reve dashboard. Keep it secret — never commit your real .env.
REVE_API_KEY=papi.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxx

# Optional overrides (sensible defaults in config.js)
# REVE_ENDPOINT=https://api.reve.com/v1/image/create
# REVE_VERSION=latest
# WO_ASPECT=9:16          # iPhone wallpaper aspect ratio

# Optional: change output base dir
# WO_HOME=C:\Users\you\WallpaperOrchestrator
